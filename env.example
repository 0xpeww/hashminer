RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# GPU settings
GPU_BINARY=./miner_gpu
BATCH_SIZE=67108864     # 64M nonce per GPU per batch (naikkan ke 134217728 untuk VRAM besar)

# CPU fallback
CORES=56                # sesuaikan jumlah CPU
CPU_FALLBACK=true       # false = matikan CPU fallback
